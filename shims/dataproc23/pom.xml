<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <parent>
    <groupId>org.pentaho.hadoop.shims</groupId>
    <artifactId>pentaho-hadoop-shims-list</artifactId>
    <version>11.1.0.0-203</version>
  </parent>
  <artifactId>pentaho-hadoop-shims-dataproc23-reactor</artifactId>
  <packaging>pom</packaging>
  <properties>
    <!-- shim properties -->
    <shim.name>dataproc23</shim.name>
    <vendor-driver.version>2.3</vendor-driver.version>
    <pentaho-code.version>11.1.0.0</pentaho-code.version>

    <!-- GCP properties -->
    <gcs-connector.version>hadoop3-2.2.32</gcs-connector.version>
    <dataproc.guava.version>32.1.2-jre</dataproc.guava.version>

    <!-- default folder -->
    <org.apache.hbase.version>2.6.2</org.apache.hbase.version>
    <automaton.version>1.11-8</automaton.version>
    <pig.version>0.18.0</pig.version>
    <org.apache.oozie.version>5.2.1</org.apache.oozie.version>
    <sqoop.version>1.4.7</sqoop.version>
    <hive-jdbc.version>3.1.3</hive-jdbc.version>
    <org.apache.avro.version>1.12.0</org.apache.avro.version>

    <!-- client and default folders -->
    <hadoop.version>3.3.6</hadoop.version>

    <!-- pmr folder -->
    <commons-configuration.version>1.6</commons-configuration.version>
    <commons-configuration2.version>2.10.1</commons-configuration2.version>
    <org.apache.hive.version>3.1.3</org.apache.hive.version>
    <!-- setting v1.14.4 so shaded jackson-databind inside parquet-hadoop-bundle's  version approximately matches jackson-databind in driver.jar -->
    <parquet.version>1.14.4</parquet.version>
    <org.antlr.version>3.5.2</org.antlr.version>
    <joda-time.version>2.9.9</joda-time.version>

  </properties>
  <modules>
    <module>pmr</module>
    <module>driver</module>
  </modules>
</project>
